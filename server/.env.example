# ═══════════════════════════════════════════════════════════════════════════
# LOCAL MACHINE ONLY — copy these lines into server/.env (never commit .env)
# ═══════════════════════════════════════════════════════════════════════════
# Use Docker Postgres from repo root:  docker compose up -d
#
BETTER_AUTH_SECRET=generate-a-long-random-string
CLIENT_URL=http://localhost:8080
BETTER_AUTH_URL=http://localhost:8080
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=focusnest
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYED APP (AWS App Runner, ECS, etc.) — set in the AWS console / task def
# ═══════════════════════════════════════════════════════════════════════════
# Do NOT put RDS passwords in the repo. Example shape:
#
# BETTER_AUTH_SECRET=<production-secret>
# CLIENT_URL=https://your-app.<region>.awsapprunner.com
# BETTER_AUTH_URL=https://your-app.<region>.awsapprunner.com
# PORT=3000
#
# DB_HOST=your-db.xxxxx.region.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=focusnest
# DB_USER=...
# DB_PASSWORD=...          # from Secrets Manager or App Runner “secrets”
# DB_SSL=true              # or omit; server defaults to SSL unless DB_SSL=false
#
# App Runner: “Configuration” → “Environment variables” / “Secrets”
# The running container does not use server/.env from git — only what AWS injects.
