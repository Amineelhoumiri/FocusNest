# ═══════════════════════════════════════════════════════════════════════════
# LOCAL MACHINE ONLY — copy these lines into server/.env (never commit .env)
# ═══════════════════════════════════════════════════════════════════════════
# Use Docker Postgres from repo root:  docker compose up -d
#
BETTER_AUTH_SECRET=generate-a-long-random-string
# Optional: separate secret for CSRF HMAC (defaults to BETTER_AUTH_SECRET).
# CSRF_SECRET=
# Set DISABLE_CSRF=1 only for special local debugging (not in production).
# DISABLE_CSRF=
# Rate limits: general /api (per IP, 15 min window) and consent writes (per minute).
# API_RATE_LIMIT_MAX=400
# CONSENT_RATE_LIMIT_MAX=30
CLIENT_URL=http://localhost:8080
BETTER_AUTH_URL=http://localhost:8080
PORT=3000

# ── Transactional email (Better Auth: verify email + password reset) ──────────
# Without RESEND_API_KEY, the server logs message content to the console (dev).
# https://resend.com — verify a domain or use onboarding@resend.dev for tests.
#
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=FocusNest <onboarding@resend.dev>
#
# Email/password login requires verified email by default. For local dev without Resend, disable with:
# REQUIRE_EMAIL_VERIFICATION=false

DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=focusnest
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ── Optional features (local or production) ──────────────────────────────────
# OPENAI_API_KEY=           # AI chat / subtask generation
# SENTRY_DSN=               # Server error tracking (separate from VITE_SENTRY_DSN on the client)
# POSTHOG_API_KEY=          # Server-side product analytics (omit = disabled)
# POSTHOG_HOST=https://eu.i.posthog.com
#
# SPOTIFY_CLIENT_ID= / SPOTIFY_CLIENT_SECRET= / SPOTIFY_REDIRECT_URI=
# GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=
# JWT_SECRET=               # used for Spotify OAuth state (generate in prod)

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYED APP (AWS App Runner, ECS, etc.) — set in the AWS console / task def
# ═══════════════════════════════════════════════════════════════════════════
# Do NOT put RDS passwords in the repo. Example shape:
#
# BETTER_AUTH_SECRET=<production-secret>
# CLIENT_URL=https://your-app.<region>.awsapprunner.com
# BETTER_AUTH_URL=https://your-app.<region>.awsapprunner.com
# PORT=3000
#
# DB_HOST=your-db.xxxxx.region.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=focusnest
# DB_USER=...
# DB_PASSWORD=...          # from Secrets Manager or App Runner “secrets”
# DB_SSL=true              # or omit; server defaults to SSL unless DB_SSL=false
#
# App Runner: “Configuration” → “Environment variables” / “Secrets”
# The running container does not use server/.env from git — only what AWS injects.
