# Copy to client/.env.local (gitignored) for local overrides.
# Vite only exposes variables prefixed with VITE_.

# Production / staging: public origin of the API if it differs from the page origin.
# Leave unset in local dev (Vite proxy sends /api to the Express app).
# VITE_API_URL=https://your-app.example.com

# Error monitoring (optional; browser)
# VITE_SENTRY_DSN=

# Product analytics (optional; browser — must match a public PostHog project key)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
